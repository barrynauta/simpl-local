# Host port mappings. Connector ports (19xxx provider / 29xxx consumer) don't
# clash with other simpl-local stacks. MinIO console is remapped to 9090 to
# avoid the schema-manager Kafka UI on 9001.
PROVIDER_DB_PORT=5432
CONSUMER_DB_PORT=5433
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9090

# Local-only credentials (do not reuse anywhere).
EDC_DB_USER=postgres
EDC_DB_PASSWORD=postgres
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
