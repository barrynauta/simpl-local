# Host ports. Defaults avoid clashes with the simpl-schema-manager stack
# (Fuseki 3030, API 8085) so both stacks can run side by side.
FUSEKI_PORT=3031
VOCABULARY_MANAGER_PORT=8086

# Fuseki admin credentials (local evaluation only — do not reuse anywhere).
FUSEKI_ADMIN_USER=admin
FUSEKI_ADMIN_PASSWORD=admin1234
