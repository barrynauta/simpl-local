@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix :     <http://example.org/simpl-local/sample-vocabulary#> .

<http://example.org/simpl-local/sample-vocabulary> a owl:Ontology ;
    rdfs:label "Sample Vocabulary" ;
    rdfs:comment "Minimal self-contained test vocabulary for the simpl-local evaluation stack. References only allowlisted standard namespaces (rdf, rdfs, owl, skos)." .

:DataResource a owl:Class ;
    rdfs:label "Data Resource" ;
    skos:definition "A resource of type data offered in a data space." .

:ApplicationResource a owl:Class ;
    rdfs:label "Application Resource" ;
    skos:definition "A resource of type application offered in a data space." .

:InfrastructureResource a owl:Class ;
    rdfs:label "Infrastructure Resource" ;
    skos:definition "A resource of type infrastructure offered in a data space." .

:offeredBy a owl:ObjectProperty ;
    rdfs:label "offered by" ;
    rdfs:comment "Relates a resource to the participant offering it." ;
    rdfs:domain :DataResource .
