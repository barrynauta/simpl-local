# simpl-schema-manager-local — local overrides
# Copy to .env and edit as needed. docker-compose.yml defaults are used if not set.

# ── Ports (change if these conflict with other running services) ──
FUSEKI_PORT=3030
KAFKA_HOST_PORT=9094
KAFKA_UI_PORT=9001
SCHEMA_MANAGER_PORT=8085
UI_PORT=4322

# ── Optional --with-notifications overlay (Mailpit + notification-service) ──
MAILPIT_SMTP_PORT=1026
MAILPIT_UI_PORT=8025

# ── Optional outbound relay from Mailpit ────────────────────────────────────
# When MAILPIT_RELAY_HOST is set and MAILPIT_RELAY_ALL_RECIPIENTS=true, every
# email Mailpit captures is ALSO relayed out through the configured SMTP
# server. This is how SSM-001 becomes observable end-to-end: with the
# notification-service producing messages to simpl123@mailinator.com and a
# real relay configured below, the public Mailinator inbox at
# https://www.mailinator.com/v4/public/inboxes.jsp?to=simpl123 receives them.
#
# WARNING: enabling this turns on real outbound mail from your machine.
# Use only for the deliberate demonstration of the SSM-001 finding.
#
# Gmail SMTP via App Password (most common — needs 2-Step Verification + an
# App Password generated at https://myaccount.google.com/apppasswords):
#   MAILPIT_RELAY_HOST=smtp.gmail.com
#   MAILPIT_RELAY_PORT=587
#   MAILPIT_RELAY_STARTTLS=true
#   MAILPIT_RELAY_AUTH=plain
#   MAILPIT_RELAY_USERNAME=you@gmail.com
#   MAILPIT_RELAY_PASSWORD=<16-char App Password, no spaces>
#   MAILPIT_RELAY_ALL_RECIPIENTS=true
MAILPIT_RELAY_HOST=
MAILPIT_RELAY_PORT=587
MAILPIT_RELAY_STARTTLS=true
MAILPIT_RELAY_AUTH=plain
MAILPIT_RELAY_USERNAME=
MAILPIT_RELAY_PASSWORD=
MAILPIT_RELAY_ALL_RECIPIENTS=false

# ── Fuseki credentials (defaults match the docker-compose) ──
FUSEKI_ADMIN_USER=admin
FUSEKI_ADMIN_PASSWORD=admin1234
