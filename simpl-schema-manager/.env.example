# simpl-schema-manager-local — local overrides
# Copy to .env and edit as needed. docker-compose.yml defaults are used if not set.

# ── Ports (change if these conflict with other running services) ──
FUSEKI_PORT=3030
KAFKA_HOST_PORT=9094
KAFKA_UI_PORT=9001
SCHEMA_MANAGER_PORT=8085
UI_PORT=4322

# ── Fuseki credentials (defaults match the docker-compose) ──
FUSEKI_ADMIN_USER=admin
FUSEKI_ADMIN_PASSWORD=admin1234
