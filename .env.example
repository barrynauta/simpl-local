# simpl-catalogue-local — env overrides.
#
# Copy this file to .env (which is gitignored) and edit only what you need.
# docker compose reads .env automatically. start.sh reads it too.

# --- Ports (only override if you have local conflicts) ---
# FC_SERVICE_PORT=8081
# POSTGRES_PORT=5432
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# --- Credentials ---
# DB_USER=postgres
# DB_PASS=postgres
# NEO4J_USER=neo4j
#
# Neo4j 5.14+ refuses the default 'neo4j' password. The default below is from
# upstream's docker/dev.env — change it if you want a non-default secret.
# NEO4J_PASSWORD=neo12345
