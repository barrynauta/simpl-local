# simpl-contract-local — local overrides
# Copy to .env and edit. docker-compose.yml defaults are used if a value is unset.

# ── Ports (change if these conflict with other running stacks) ──
POSTGRES_PORT=5433
KAFKA_HOST_PORT=9095
KAFKA_UI_PORT=9002
CONTRACT_API_PORT=8086
UI_PORT=4323

# ── Backend build: EU GitLab Maven registry token ───────────────────────────
# The backend depends on eu.europa.ec.simpl:simpl-common:3.3.0, served from the
# Simpl-Open GitLab Package Registry (group 4086). In CI this is fetched with
# CI_JOB_TOKEN. Locally the build first TRIES anonymously; if that 401s, set a
# code.europa.eu Personal Access Token with read_api scope here and re-run
# ./start.sh --rebuild. Leave empty to attempt the anonymous path.
GITLAB_TOKEN=

# ── UI build: auth mode (BUILD-TIME — baked into the bundle by Vite) ─────────
# VITE_PUBLIC_AUTH_MODE is added by the ui-overlay/ (see ui-overlay/README.md):
#   disabled  → no Keycloak; the UI runs with a static local identity, no login
#   keycloak  → upstream OIDC/PKCE login against the Keycloak below
# Default here is `disabled` so the local UI is usable out of the box. The
# Keycloak values are only used when the mode is `keycloak`; they point at the
# upstream dev sandbox (requires a `participant`-realm account, and the app's
# redirect URI is hardcoded to localhost:3001 — see README).
VITE_PUBLIC_AUTH_MODE=disabled
VITE_PUBLIC_AUTH_KEYCLOAK_SERVER_URL=https://participant.be.dataprovider01.dev-sandbox-ionos.simpl-europe.eu
VITE_PUBLIC_AUTH_KEYCLOAK_REALM=participant
VITE_PUBLIC_AUTH_KEYCLOAK_CLIENT_ID=frontend-cli
