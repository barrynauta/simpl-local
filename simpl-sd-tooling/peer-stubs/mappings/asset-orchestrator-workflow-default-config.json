{
  "name": "asset-orchestrator: GET workflow default config (UI workflow picker detail)",
  "request": {
    "method": "GET",
    "urlPathPattern": "/v1/workflows/[^/]+/[^/]+/[^/]+/defaultConfig"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "jobName": "data_pipeline",
      "repositoryName": "local-repository",
      "codeLocation": "local-code-location",
      "defaultYamlConfig": "ops:\n  process_data:\n    config:\n      url: https://example.local\n"
    }
  }
}
