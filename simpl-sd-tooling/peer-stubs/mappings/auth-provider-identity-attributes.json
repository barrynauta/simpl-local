    "jsonBody": {
      "items": [
        { "name": "Data Consumer", "code": "IA-DATA-CONSUMER", "enabled": true, "assignableToRoles": true },
        { "name": "Data Provider", "code": "IA-DATA-PROVIDER", "enabled": true, "assignableToRoles": true },
        { "name": "Application Provider", "code": "IA-APP-PROVIDER", "enabled": true, "assignableToRoles": true },
        { "name": "Infrastructure Provider", "code": "IA-INFRA-PROVIDER", "enabled": true, "assignableToRoles": true }
      ]
    }
  }
}
