# simpl-notification-service-local — local overrides
# Copy to .env and edit as needed. docker-compose.yml defaults are used if not set.

# ── Ports (change if these conflict with other running services) ──
KAFKA_HOST_PORT=9093
KAFKA_UI_PORT=9082
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
NOTIFICATION_SERVICE_PORT=8082

# ── Notification settings ──
# Email address used as the default receiver for notifications
DEFAULT_EMAIL_RECEIVER=test@example.com

# ── Security ──
# API key used by the notification service (spring.api-key)
API_KEY=local-dev-api-key
