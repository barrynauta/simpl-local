# Local-only discovery / scratch notes — never push these.
# They contain transient observations, may include path leakage, and
# should be regenerated, not version-controlled.
discovery-report-*.md
discovery-notes/
notes/

# Project plans — local working documents, not part of the published repo.
# The Notion page (Catalogue Installation — Local Installation) is the
# authoritative plan tracker; these are working scratch.
_planning/
plans/
PLAN*.md
*.plan.md
project-plan*.md

# Upstream code cloned at runtime by start.sh.
# This repo holds scripts + docs only. Upstream Simpl-Open repos live
# in repos/ and must be re-cloned from code.europa.eu by the user.
repos/

# Build artefacts produced by start.sh / the Docker build context.
build/
target/
node_modules/

# Local environment overrides (keep .env.example committed).
.env.local
.env.*.local

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/
.venv/

# Claude Code per-project settings (user-specific permissions, paths).
.claude/settings.local.json
